name: Automatic Code Compiler and Merger

on:
  push:
    branches:
      - main
  workflow_dispatch:

permissions:
  contents: write

jobs:
  merge-and-deploy:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout Repository Code
        uses: actions/checkout@v4

      - name: Compile and Merge Files Natively
        run: |
          # Use absolute workspace environment paths to force clear whitespace errors
          if [ ! -f "${{ github.workspace }}/layout.html" ] || [ ! -f "${{ github.workspace }}/engine.html" ]; then
            echo "Error: Code components missing from root directory."
            exit 1
          fi
          
          # Force clean compilation of Part 1 and Part 2 into a single index.html document
          cat "${{ github.workspace }}/layout.html" "${{ github.workspace }}/engine.html" > "${{ github.workspace }}/index.html"
          echo "Code matrix merged successfully into index.html."

      - name: Commit and Push Merged Output
        run: |
          git config --global user.name "Matrix Compiler Bot"
          git config --global user.email "compiler@matrix-engine.local"
          git add index.html
          git diff-index --quiet HEAD || git commit -m "Automated System Compiler: Insulated file merge complete"
          git push
